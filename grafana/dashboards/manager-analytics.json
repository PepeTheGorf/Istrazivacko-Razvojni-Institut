        {
          "datasource": {
            "type": "postgres",
            "uid": "project-realization-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  ta.assignee_id::text AS \"Član\",\n  COUNT(DISTINCT ta.task_id) AS \"Dodeljeni zadaci\",\n  COUNT(DISTINCT CASE\n    WHEN t.phase_id = (\n      SELECT p.id\n      FROM phases p\n      WHERE p.workflow_id = t.workflow_id\n      ORDER BY p.phase_order DESC\n      LIMIT 1\n    ) THEN ta.task_id\n  END) AS \"Završeni\",\n  COUNT(DISTINCT CASE\n    WHEN t.end_date < NOW() THEN ta.task_id\n  END) AS \"Prekoračeni rok\"\nFROM task_assignments ta\nJOIN tasks t ON t.id = ta.task_id\nWHERE t.project_id = ${project_id}\nGROUP BY ta.assignee_id\nORDER BY COUNT(DISTINCT ta.task_id) DESC;",
          "refId": "A"
        }
      ],
      "title": "Opterećenje članova tima",
      "type": "barchart"
    },
