          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  p.name AS \"Faza\",\n  COUNT(t.id) AS \"Broj zadataka\"\nFROM tasks t\nJOIN phases p ON p.id = t.phase_id\nWHERE t.project_id = ${project_id}\nGROUP BY p.name, p.phase_order\nORDER BY p.phase_order;",
