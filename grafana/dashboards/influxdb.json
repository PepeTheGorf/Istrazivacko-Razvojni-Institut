{
  "title": "InfluxDB - Realizacija projekata",
  "uid": "influxdb-project-realization",
  "version": 5,
  "schemaVersion": 36,
  "refresh": "",
  "timezone": "browser",
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {
    "hidden": false,
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d", "90d", "6M", "1y", "2y", "5y"]
  },
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "name": "project",
        "label": "Projekat",
        "type": "query",
        "datasource": { "type": "influxdb", "uid": "influxdb" },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"project-analytics\", tag: \"projectName\")",
        "refresh": 1,
        "sort": 1,
        "current": { "text": "project-1", "value": "project-1" }
      },
      {
        "name": "fromPhase",
        "label": "Izlazna faza",
        "type": "custom",
        "query": "All, BACKLOG, IN_PROGRESS, REVIEW, DONE",
        "options": [
          { "text": "Sve", "value": "All", "selected": true },
          { "text": "BACKLOG", "value": "BACKLOG", "selected": false },
          { "text": "IN_PROGRESS", "value": "IN_PROGRESS", "selected": false },
          { "text": "REVIEW", "value": "REVIEW", "selected": false },
          { "text": "DONE", "value": "DONE", "selected": false }
        ],
        "current": { "text": "Sve", "value": "All" }
      },
      {
        "name": "minDuration",
        "label": "Min. trajanje (s)",
        "type": "textbox",
        "current": { "text": "3600", "value": "3600" }
      },
      {
        "name": "maxDuration",
        "label": "Max. trajanje (s)",
        "type": "textbox",
        "current": { "text": "86400", "value": "86400" }
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "title": "Proste sekcije",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "Prelazi faza za projekat (opcioni filter po fazi)",
      "description": "Prosta sekcija: dobavljanje slogova iz baze, filter: projekat + izlazna faza.",
      "type": "table",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"project-analytics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"task_phase_transitions\")\n  |> filter(fn: (r) => r[\"_field\"] == \"durationSeconds\")\n  |> filter(fn: (r) => r[\"projectName\"] == \"${project}\")\n  |> filter(fn: (r) => r[\"fromPhase\"] == \"${fromPhase}\" or \"${fromPhase}\" == \"All\")\n  |> keep(columns: [\"_time\", \"taskId\", \"fromPhase\", \"toPhase\", \"userId\", \"_value\"])\n  |> sort(columns: [\"_time\"], desc: true)\n  |> limit(n: 100)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "cellOptions": { "type": "auto" } }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "_time" },
            "properties": [{ "id": "displayName", "value": "Vreme" }]
          },
          {
            "matcher": { "id": "byName", "options": "_value" },
            "properties": [
              { "id": "displayName", "value": "Trajanje" },
              { "id": "unit", "value": "s" }
            ]
          }
        ]
      },
      "options": {
        "cellHeight": "sm",
        "showHeader": true,
        "footer": { "show": false }
      }
    },
    {
      "id": 2,
      "title": "Prelazi u opsegu trajanja (min–max sekundi)",
      "description": "Prosta sekcija: slogovi filtrirani po trajanju u prelazu.",
      "type": "table",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"project-analytics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"task_phase_transitions\")\n  |> filter(fn: (r) => r[\"_field\"] == \"durationSeconds\")\n  |> filter(fn: (r) => r[\"projectName\"] == \"${project}\")\n  |> filter(fn: (r) => r[\"_value\"] >= ${minDuration})\n  |> filter(fn: (r) => r[\"_value\"] <= ${maxDuration})\n  |> keep(columns: [\"_time\", \"taskId\", \"fromPhase\", \"toPhase\", \"userId\", \"_value\"])\n  |> sort(columns: [\"_value\"], desc: true)\n  |> limit(n: 100)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "cellOptions": { "type": "auto" } }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "_time" },
            "properties": [{ "id": "displayName", "value": "Vreme" }]
          },
          {
            "matcher": { "id": "byName", "options": "_value" },
            "properties": [
              { "id": "displayName", "value": "Trajanje" },
              { "id": "unit", "value": "s" }
            ]
          }
        ]
      },
      "options": {
        "cellHeight": "sm",
        "showHeader": true,
        "footer": { "show": false }
      }
    },
    {
      "id": 200,
      "title": "Složena sekcija",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 },
      "collapsed": false
    },
    {
      "id": 3,
      "title": "Prosečno trajanje po fazi",
      "description": "Slozena sekcija: agregacija mean(durationSeconds) grupisano po fromPhase",
      "type": "barchart",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"project-analytics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"task_phase_transitions\")\n  |> filter(fn: (r) => r[\"_field\"] == \"durationSeconds\")\n  |> filter(fn: (r) => r[\"projectName\"] == \"${project}\")\n  |> group(columns: [\"fromPhase\"])\n  |> mean(column: \"_value\")\n  |> group()\n  |> sort(columns: [\"_value\"], desc: true)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s",
          "decimals": 1,
          "custom": {
            "fillOpacity": 80,
            "axisSoftMin": 0,
            "axisPlacement": "auto"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "_value" },
            "properties": [{ "id": "displayName", "value": "Prosečno vreme" }]
          }
        ]
      },
      "options": {
        "orientation": "horizontal",
        "xField": "fromPhase",
        "showValue": "auto",
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 200,
        "xTickLabelMaxLength": 16,
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false }
      }
    }
  ],
  "annotations": { "list": [] }
}
